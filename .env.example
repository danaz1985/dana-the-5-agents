# ===== מפתחות API =====
# מפתח ה-API של Anthropic (Claude) — המוח של הסוכנים
ANTHROPIC_API_KEY=

# ===== הגדרות מודלים =====
# המודל הראשי שבו משתמשים הסוכנים
ANTHROPIC_MODEL=claude-opus-4-8

# ===== יובל — מעצב התמונות (אופציונלי) =====
# מפתח לשירות יצירת תמונות (למשל OpenAI / Stability / אחר)
IMAGE_API_KEY=

# ===== חן — החוקרת (אופציונלי) =====
# מפתח לשירות חיפוש/מחקר (למשל Tavily / Serper / אחר)
RESEARCH_API_KEY=

# ===== כללי =====
# סביבת הרצה: development | production
NODE_ENV=development
